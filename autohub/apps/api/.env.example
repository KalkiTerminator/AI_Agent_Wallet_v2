# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/autohub

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in the web app
NEXTAUTH_SECRET=your-secret-here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Stripe credit pack price IDs (one per pack)
STRIPE_CREDITS_100_PRICE_ID=price_...
STRIPE_CREDITS_500_PRICE_ID=price_...
STRIPE_CREDITS_1000_PRICE_ID=price_...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Comma-separated list of allowed web origins (no trailing slash)
AUTOHUB_WEB_URL=https://autohub.vercel.app

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://....ingest.sentry.io/...
