# ── NextAuth ──────────────────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in the API
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://autohub.vercel.app

# ── API ───────────────────────────────────────────────────────────────────────
# Deployed Railway URL
NEXT_PUBLIC_API_URL=https://autohub-api.up.railway.app

# ── Sentry ────────────────────────────────────────────────────────────────────
# Public DSN is safe to expose (it's read-only)
NEXT_PUBLIC_SENTRY_DSN=https://....ingest.sentry.io/...
# Server-side DSN (same value, different env var so it's not bundled into client JS)
SENTRY_DSN=https://....ingest.sentry.io/...
# Required for source map uploads during build
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=autohub-web
