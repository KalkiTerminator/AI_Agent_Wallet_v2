# Playwright E2E environment variables
# Copy this to .env.e2e.local and fill in any overrides before running locally.

# Base URL — override in CI to point at a deployed preview
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Test user credentials — must match what e2e-seed.ts creates
E2E_TEST_EMAIL=e2e@autohub.test
E2E_TEST_PASSWORD=e2epassword123

E2E_ADMIN_EMAIL=admin-e2e@autohub.test
E2E_ADMIN_PASSWORD=e2epassword123

# Production smoke tests — points at live site
SMOKE_BASE_URL=https://www.autohub.fun
